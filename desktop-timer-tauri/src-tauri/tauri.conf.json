{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arch Time Mini Timer",
  "version": "0.2.0",
  "identifier": "it.archtimepro.timer.light",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Arch Time Mini Timer",
        "width": 430,
        "height": 740,
        "minWidth": 430,
        "minHeight": 740,
        "maxWidth": 430,
        "maxHeight": 740,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' https://www.archtimepro.it https://unpkg.com https://*.supabase.co; script-src 'self' https://www.archtimepro.it https://unpkg.com; style-src 'self' 'unsafe-inline'; connect-src 'self' https://www.archtimepro.it https://*.supabase.co wss://*.supabase.co; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
