{
  "name": "arch-time-mini-timer",
  "version": "0.1.0",
  "description": "Arch Time Pro desktop timer companion for Windows.",
  "main": "main.js",
  "private": true,
  "author": "Arch Time Pro",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis --x64"
  },
  "build": {
    "appId": "it.archtimepro.timer",
    "productName": "Arch Time Mini Timer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "assets/**",
      "renderer/**"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Arch Time Mini Timer"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
